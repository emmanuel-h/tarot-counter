<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer: the three bouts (oudlers) of French Tarot, fanned like a hand.

      Left  card (−22°): Le Petit  — Trump I   — bold "1" in upper portion
      Centre card (0°):  L'Excuse             — jester hat with three bells
      Right card (+22°): Le Monde  — Trump XXI — bold "21" in upper portion

    All three cards share the same unrotated base shape (x=38–70, y=30–80) and are
    rotated around pivot (54, 95) — below the canvas — to fan out naturally.
    Drawing order: left → right → centre (centre is topmost / drawn in front).

    Rotation increased from 16° to 22° so the side-card numerals clear the
    centre card and remain within the adaptive-icon safe zone (72×72 dp centred).

    Colour palette
        #F2E0A0  warm parchment  (card body)
        #C4972A  antique gold    (borders, bells)
        #2A0F5E  deep purple     (numerals, jester hat body)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═══════════════════════════════════════════════════════════════════════
         LEFT CARD — Le Petit (Trump I)
         Rotated −22° around (54, 95): top swings left, exposing the "1".
         ═══════════════════════════════════════════════════════════════════════ -->
    <group
        android:rotation="-22"
        android:pivotX="54"
        android:pivotY="95">

        <!-- Parchment body -->
        <path
            android:fillColor="#F2E0A0"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold outer border -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="1.5"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold inner frame -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="0.75"
            android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

        <!--
            Large "1" numeral — shifted toward the outer (left) edge of the card
            so it stays visible after the −22° rotation.

            Shape: a vertical bar (x=44–54) with a diagonal serif/flag at the
            top-left — exactly how the numeral appears on a real playing card.

            M40,50  → flag tip (bottom-left of serif)
            L44,36  → flag top (joins the main bar at its top-left corner)
            H54     → top-right corner of bar
            V72     → bottom-right corner of bar
            H44     → bottom-left corner of bar
            V50     → back up to flag base
            Z       → close
        -->
        <path
            android:fillColor="#2A0F5E"
            android:pathData="M40,50 L44,36 H54 V72 H44 V50 Z" />

    </group>

    <!-- ═══════════════════════════════════════════════════════════════════════
         RIGHT CARD — Le Monde (Trump XXI)
         Rotated +22° around (54, 95): top swings right, exposing the "21".
         ═══════════════════════════════════════════════════════════════════════ -->
    <group
        android:rotation="22"
        android:pivotX="54"
        android:pivotY="95">

        <!-- Parchment body -->
        <path
            android:fillColor="#F2E0A0"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold outer border -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="1.5"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold inner frame -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="0.75"
            android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

        <!--
            Large "21" numeral — drawn in 7-segment style.

            At +22° rotation the LEFT side of this card is hidden behind the
            centre card, so the digits are placed within the inner frame
            (x=42–66) and the visible upper portion reads clearly as "21".

            Digit "2" occupies x=42–54, y=36–70, segment thickness = 3dp:
              a = top bar        (y=36–39)
              b = top-right leg  (x=51–54, y=36–53)
              g = middle bar     (y=53–56)
              e = bottom-left leg(x=42–45, y=56–70)
              d = bottom bar     (y=67–70)

            Digit "1" occupies x=55–65, y=36–70:
              vertical bar with a small diagonal flag at top-left.
        -->
        <!-- 2 – segment a (top bar) -->
        <path android:fillColor="#2A0F5E" android:pathData="M42,36 H54 V39 H42 Z" />
        <!-- 2 – segment b (top-right leg) -->
        <path android:fillColor="#2A0F5E" android:pathData="M51,36 H54 V53 H51 Z" />
        <!-- 2 – segment g (middle bar) -->
        <path android:fillColor="#2A0F5E" android:pathData="M42,53 H54 V56 H42 Z" />
        <!-- 2 – segment e (bottom-left leg) -->
        <path android:fillColor="#2A0F5E" android:pathData="M42,56 H45 V70 H42 Z" />
        <!-- 2 – segment d (bottom bar) -->
        <path android:fillColor="#2A0F5E" android:pathData="M42,67 H54 V70 H42 Z" />
        <!-- 1 – vertical bar with diagonal flag (same proportions as the left card) -->
        <path android:fillColor="#2A0F5E" android:pathData="M53,51 L56,36 H65 V70 H56 V51 Z" />

    </group>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CENTRE CARD — L'Excuse  (drawn last = topmost / always in front)
         No rotation. Shows a jester hat — the universal symbol of the Fool,
         which is what L'Excuse represents in French Tarot.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Parchment body -->
    <path
        android:fillColor="#F2E0A0"
        android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
    <!-- Gold outer border -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4972A"
        android:strokeWidth="1.5"
        android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
    <!-- Gold inner frame -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4972A"
        android:strokeWidth="0.75"
        android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

    <!--
        Jester hat — three upward prongs with a bell at each tip and a brim
        at the base. The centre prong is the tallest (classic fool's cap shape).

        Prong tips (bottom of each bell diamond):
          Left   prong: (41, 50)
          Centre prong: (54, 39)   ← tallest
          Right  prong: (67, 50)

        Hat body — a W-shaped polygon connecting the prong tips with the brim:
          M44,66  left  brim edge
          L41,50  up to left  prong tip
          L48,53  valley between left  and centre prongs
          L54,39  up to centre prong tip
          L60,53  valley between centre and right  prongs
          L67,50  up to right prong tip
          L64,66  right brim edge
          Z
    -->
    <path
        android:fillColor="#2A0F5E"
        android:pathData="M44,66 L41,50 L48,53 L54,39 L60,53 L67,50 L64,66 Z" />

    <!--
        Hat brim — a filled horizontal band anchoring the hat to the card.
        Slightly wider than the hat body to give a clear base line.
    -->
    <path
        android:fillColor="#2A0F5E"
        android:pathData="M39,66 H69 V71 H39 Z" />

    <!--
        Three bells (gold diamond shapes) — one at each prong tip.
        Gold colour distinguishes them from the hat body and evokes
        the jingling bells on a real jester's cap.

        Each diamond: M centre,top L right,mid L centre,bottom L left,mid Z
    -->
    <!-- Left bell — centred at (41, 47), half-width 3 dp -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M41,44 L44,47 L41,50 L38,47 Z" />
    <!-- Centre bell — centred at (54, 35), half-width 4 dp (slightly larger) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M54,31 L58,35 L54,39 L50,35 Z" />
    <!-- Right bell — centred at (67, 47), half-width 3 dp -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M67,44 L70,47 L67,50 L64,47 Z" />

</vector>
