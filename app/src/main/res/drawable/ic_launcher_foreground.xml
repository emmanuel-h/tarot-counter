<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer: the three bouts (oudlers) of French Tarot, fanned like a hand.

      Left  card (−22°): Le Petit  — Trump I   — bold "1" in top-left corner
      Centre card (0°):  L'Excuse             — jester head with hat and gold stars
      Right card (+22°): Le Monde  — Trump XXI — bold "21" in top-right corner

    The numerals are placed in the outermost visible corner of each side card
    (top-left for the left card, top-right for the right card) so they are
    always fully exposed regardless of the fan angle.

    Drawing order: left → right → centre (centre is topmost / drawn in front).
    All three cards rotate around pivot (54, 95) — below the canvas.

    Colour palette
        #FFFFFF  white           (card bodies, lute soundboard)
        #C4972A  antique gold    (borders, hat band, bell, stars)
        #2A0F5E  deep purple     (numerals, jester hat and features)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═══════════════════════════════════════════════════════════════════════
         LEFT CARD — Le Petit (Trump I)
         Rotated −22° around (54, 95): top swings left.
         The top-left corner of this card is the most visible area.
         ═══════════════════════════════════════════════════════════════════════ -->
    <group
        android:rotation="-22"
        android:pivotX="54"
        android:pivotY="95">

        <!-- Parchment body -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold outer border -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="1.5"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold inner frame -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="0.75"
            android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

        <!--
            Bold "1" in the top-left corner — the outermost visible area after
            the −22° rotation. Bar width is 4 dp to match the stroke thickness
            used in the "21" on the right card. A diagonal serif/flag at the
            top-left distinguishes it from a plain rectangle.

            M44,46  → flag base (bottom-left of serif)
            L48,35  → flag tip  (joins bar at its top-left corner)
            H52     → top-right corner of bar  (4 dp wide: x=48–52)
            V57     → bottom-right corner of bar
            H48     → bottom-left corner of bar
            V46     → back up to flag base
            Z       → close
        -->
        <path
            android:fillColor="#2A0F5E"
            android:pathData="M44,46 L48,35 H52 V57 H48 V46 Z" />

    </group>

    <!-- ═══════════════════════════════════════════════════════════════════════
         RIGHT CARD — Le Monde (Trump XXI)
         Rotated +22° around (54, 95): top swings right.
         The top-right corner of this card is the most visible area.
         ═══════════════════════════════════════════════════════════════════════ -->
    <group
        android:rotation="22"
        android:pivotX="54"
        android:pivotY="95">

        <!-- Parchment body -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold outer border -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="1.5"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold inner frame -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="0.75"
            android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

        <!--
            Bold "21" in the top-right corner — 7-segment style, two digits.
            Digit "2" occupies x=52–61, y=35–57 (segment thickness = 2 dp).
            Digit "1" occupies x=62–66, y=35–57 (simple filled bar).
        -->
        <!-- 2 – segment a (top bar, 3 dp thick) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,35 H61 V38 H52 Z" />
        <!-- 2 – segment b (top-right leg, 3 dp wide) -->
        <path android:fillColor="#2A0F5E" android:pathData="M58,35 H61 V48 H58 Z" />
        <!-- 2 – segment g (middle bar, 3 dp thick) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,45 H61 V48 H52 Z" />
        <!-- 2 – segment e (bottom-left leg, 3 dp wide) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,48 H55 V57 H52 Z" />
        <!-- 2 – segment d (bottom bar, 3 dp thick) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,54 H61 V57 H52 Z" />
        <!-- 1 – vertical bar (4 dp wide, matches visual weight of the "2") -->
        <path android:fillColor="#2A0F5E" android:pathData="M62,35 H66 V57 H62 Z" />

    </group>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CENTRE CARD — L'Excuse  (drawn last = topmost / always in front)
         No rotation. Shows the four suit symbols (♥ ♠ ♦ ♣) in a 2×2 grid,
         surrounded by four 4-pointed gold stars in the corners.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Parchment body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
    <!-- Gold outer border -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4972A"
        android:strokeWidth="1.5"
        android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
    <!-- Gold inner frame -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4972A"
        android:strokeWidth="0.75"
        android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

    <!--
        ── SUIT SYMBOLS ─────────────────────────────────────────────────────────

        The four French playing-card suits in a 2×2 grid inside the inner frame.
        Hearts and diamonds: red (#CC0000). Spades and clubs: black (#000000).

          Top-left     ♥ Heart    centre (48, 47)   x=42–54, y=41–53
          Top-right    ♠ Spade    centre (60, 47)   x=54–66, y=41–54
          Bottom-left  ♦ Diamond  centre (48, 62)   x=42–54, y=56–68
          Bottom-right ♣ Club     centre (60, 62)   x=54–66, y=56–70
    -->

    <!--
        ♥ Heart — two upper bumps meeting at a centre notch, tapering to a
        bottom point. Drawn as a single closed cubic-Bézier path.
    -->
    <path
        android:fillColor="#CC0000"
        android:pathData="M48,53 C45,50 42,48 42,46 C42,43 44,41 47,41 C47.5,41 48,42 48,43 C48,42 48.5,41 49,41 C52,41 54,43 54,46 C54,48 51,50 48,53 Z" />

    <!--
        ♠ Spade — an inverted heart body (top tip pointing up) with a small
        trapezoidal foot/collar at the bottom, just like on a real playing card.
    -->
    <path
        android:fillColor="#000000"
        android:pathData="M60,41 C64,44 66,46 66,48 C66,51 63,52 60,51 C63,52 64,53 64,54 H56 C56,53 57,52 60,51 C57,52 54,51 54,48 C54,46 56,44 60,41 Z" />

    <!-- ♦ Diamond — a simple axis-aligned rhombus -->
    <path
        android:fillColor="#CC0000"
        android:pathData="M48,56 L54,62 L48,68 L42,62 Z" />

    <!--
        ♣ Club — three overlapping circles (trefoil) with a narrow stem and
        a wider base bar, mirroring the standard club glyph.
    -->
    <!-- Top circle, centre (60, 59), r=3 -->
    <path android:fillColor="#000000"
        android:pathData="M57,59 A3,3,0,0,1,63,59 A3,3,0,0,1,57,59 Z" />
    <!-- Left circle, centre (57, 63), r=3 -->
    <path android:fillColor="#000000"
        android:pathData="M54,63 A3,3,0,0,1,60,63 A3,3,0,0,1,54,63 Z" />
    <!-- Right circle, centre (63, 63), r=3 -->
    <path android:fillColor="#000000"
        android:pathData="M60,63 A3,3,0,0,1,66,63 A3,3,0,0,1,60,63 Z" />
    <!-- Stem -->
    <path android:fillColor="#000000" android:pathData="M59,66 H61 V69 H59 Z" />
    <!-- Base bar -->
    <path android:fillColor="#000000" android:pathData="M57,69 H63 V70.5 H57 Z" />

    <!--
        ── CORNER STARS ─────────────────────────────────────────────────────────

        Four 4-pointed gold stars, one near each corner of the inner frame.
        Each star has 4 outer tips (N/S/E/W) and 4 inner corners (diagonals).
        Outer radius ≈ 4 dp, inner radius ≈ 1.5 dp.

        Shape (clockwise from top tip, centre cx,cy):
          M cx,cy-4    (top)
          L cx+1.5,cy-1.5  (upper-right inner)
          L cx+4,cy    (right)
          L cx+1.5,cy+1.5  (lower-right inner)
          L cx,cy+4    (bottom)
          L cx-1.5,cy+1.5  (lower-left inner)
          L cx-4,cy    (left)
          L cx-1.5,cy-1.5  (upper-left inner)
          Z
    -->
    <!-- Top-left star, centre (45, 38) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M45,34 L46.5,36.5 L49,38 L46.5,39.5 L45,42 L43.5,39.5 L41,38 L43.5,36.5 Z" />
    <!-- Top-right star, centre (63, 38) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M63,34 L64.5,36.5 L67,38 L64.5,39.5 L63,42 L61.5,39.5 L59,38 L61.5,36.5 Z" />
    <!-- Bottom-left star, centre (45, 72) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M45,68 L46.5,70.5 L49,72 L46.5,73.5 L45,76 L43.5,73.5 L41,72 L43.5,70.5 Z" />
    <!-- Bottom-right star, centre (63, 72) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M63,68 L64.5,70.5 L67,72 L64.5,73.5 L63,76 L61.5,73.5 L59,72 L61.5,70.5 Z" />

</vector>
