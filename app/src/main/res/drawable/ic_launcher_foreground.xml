<?xml version="1.0" encoding="utf-8"?>
<!--
    Foreground layer: the three bouts (oudlers) of French Tarot, fanned like a hand.

      Left  card (−22°): Le Petit  — Trump I   — bold "1" in top-left corner
      Centre card (0°):  L'Excuse             — jester head with hat and gold stars
      Right card (+22°): Le Monde  — Trump XXI — bold "21" in top-right corner

    The numerals are placed in the outermost visible corner of each side card
    (top-left for the left card, top-right for the right card) so they are
    always fully exposed regardless of the fan angle.

    Drawing order: left → right → centre (centre is topmost / drawn in front).
    All three cards rotate around pivot (54, 95) — below the canvas.

    Colour palette
        #F2E0A0  warm parchment  (card bodies, jester face)
        #C4972A  antique gold    (borders, hat band, bell, stars)
        #2A0F5E  deep purple     (numerals, jester hat and features)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ═══════════════════════════════════════════════════════════════════════
         LEFT CARD — Le Petit (Trump I)
         Rotated −22° around (54, 95): top swings left.
         The top-left corner of this card is the most visible area.
         ═══════════════════════════════════════════════════════════════════════ -->
    <group
        android:rotation="-22"
        android:pivotX="54"
        android:pivotY="95">

        <!-- Parchment body -->
        <path
            android:fillColor="#F2E0A0"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold outer border -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="1.5"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold inner frame -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="0.75"
            android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

        <!--
            Bold "1" in the top-left corner — the outermost visible area after
            the −22° rotation. The numeral uses a vertical bar with a diagonal
            serif/flag at the top-left, exactly like on a real playing card.

            M42,46  → flag base (bottom-left of serif)
            L46,35  → flag tip  (joins bar at its top-left corner)
            H56     → top-right corner of bar
            V57     → bottom-right corner of bar
            H46     → bottom-left corner of bar
            V46     → back up to flag base
            Z       → close
        -->
        <path
            android:fillColor="#2A0F5E"
            android:pathData="M42,46 L46,35 H56 V57 H46 V46 Z" />

    </group>

    <!-- ═══════════════════════════════════════════════════════════════════════
         RIGHT CARD — Le Monde (Trump XXI)
         Rotated +22° around (54, 95): top swings right.
         The top-right corner of this card is the most visible area.
         ═══════════════════════════════════════════════════════════════════════ -->
    <group
        android:rotation="22"
        android:pivotX="54"
        android:pivotY="95">

        <!-- Parchment body -->
        <path
            android:fillColor="#F2E0A0"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold outer border -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="1.5"
            android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
        <!-- Gold inner frame -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#C4972A"
            android:strokeWidth="0.75"
            android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

        <!--
            Bold "21" in the top-right corner — 7-segment style, two digits.
            Digit "2" occupies x=52–61, y=35–57 (segment thickness = 2 dp).
            Digit "1" occupies x=62–66, y=35–57 (simple filled bar).
        -->
        <!-- 2 – segment a (top bar) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,35 H61 V37 H52 Z" />
        <!-- 2 – segment b (top-right leg) -->
        <path android:fillColor="#2A0F5E" android:pathData="M59,35 H61 V46 H59 Z" />
        <!-- 2 – segment g (middle bar) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,46 H61 V48 H52 Z" />
        <!-- 2 – segment e (bottom-left leg) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,48 H54 V57 H52 Z" />
        <!-- 2 – segment d (bottom bar) -->
        <path android:fillColor="#2A0F5E" android:pathData="M52,55 H61 V57 H52 Z" />
        <!-- 1 – vertical bar -->
        <path android:fillColor="#2A0F5E" android:pathData="M62,35 H66 V57 H62 Z" />

    </group>

    <!-- ═══════════════════════════════════════════════════════════════════════
         CENTRE CARD — L'Excuse  (drawn last = topmost / always in front)
         No rotation. Shows a jester head — face, pointed cap, gold hat band,
         and gold bell — surrounded by four 4-pointed gold stars in the corners.
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Parchment body -->
    <path
        android:fillColor="#F2E0A0"
        android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
    <!-- Gold outer border -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4972A"
        android:strokeWidth="1.5"
        android:pathData="M41,30 Q38,30 38,33 V77 Q38,80 41,80 H67 Q70,80 70,77 V33 Q70,30 67,30 Z" />
    <!-- Gold inner frame -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4972A"
        android:strokeWidth="0.75"
        android:pathData="M44,34 Q42,34 42,36 V74 Q42,76 44,76 H64 Q66,76 66,74 V36 Q66,34 64,34 Z" />

    <!--
        ── JESTER HEAD ──────────────────────────────────────────────────────────

        Layers drawn bottom-to-top:
          1. Parchment face circle (with purple stroke so it shows on parchment bg)
          2. Deep-purple pointed hat triangle — covers the top of the face
          3. Gold hat band — crisp separation between hat and face
          4. Gold bell diamond — tip of the hat
          5. Eyes and smile — deep purple on the parchment face

        Face circle: centre (54, 60), radius 11 dp → spans y=49–71.
        Hat triangle: base at y=49 (top of face), tip at y=33.
        The hat therefore sits on the head without any gap.
    -->

    <!-- 1. Face — parchment circle with dark outline so it reads on the card -->
    <path
        android:fillColor="#F2E0A0"
        android:strokeColor="#2A0F5E"
        android:strokeWidth="1.5"
        android:pathData="M43,60 A11,11,0,0,1,65,60 A11,11,0,0,1,43,60 Z" />

    <!-- 2. Pointed jester hat — an upward triangle covering the top of the face -->
    <path
        android:fillColor="#2A0F5E"
        android:pathData="M44,49 L64,49 L54,33 Z" />

    <!-- 3. Gold hat band — separates hat brim from face (5 dp tall) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M44,49 H64 V53 H44 Z" />

    <!--
        4. Gold bell diamond at the tip of the hat.
           Centre (54, 33), half-width 4 dp.
           M54,29 → top tip
           L58,33 → right tip
           L54,37 → bottom tip (meets hat tip)
           L50,33 → left tip
           Z
    -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M54,29 L58,33 L54,37 L50,33 Z" />

    <!-- 5a. Left eye — small filled square, deep purple -->
    <path
        android:fillColor="#2A0F5E"
        android:pathData="M49,57 H51.5 V59.5 H49 Z" />

    <!-- 5b. Right eye — small filled square, deep purple -->
    <path
        android:fillColor="#2A0F5E"
        android:pathData="M56.5,57 H59 V59.5 H56.5 Z" />

    <!-- 5c. Smile — a gentle upward curve (quadratic Bézier), stroke only -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#2A0F5E"
        android:strokeWidth="1.5"
        android:pathData="M50,63 Q54,67.5 58,63" />

    <!--
        ── CORNER STARS ─────────────────────────────────────────────────────────

        Four 4-pointed gold stars, one near each corner of the inner frame.
        Each star has 4 outer tips (N/S/E/W) and 4 inner corners (diagonals).
        Outer radius ≈ 4 dp, inner radius ≈ 1.5 dp.

        Shape (clockwise from top tip, centre cx,cy):
          M cx,cy-4    (top)
          L cx+1.5,cy-1.5  (upper-right inner)
          L cx+4,cy    (right)
          L cx+1.5,cy+1.5  (lower-right inner)
          L cx,cy+4    (bottom)
          L cx-1.5,cy+1.5  (lower-left inner)
          L cx-4,cy    (left)
          L cx-1.5,cy-1.5  (upper-left inner)
          Z
    -->
    <!-- Top-left star, centre (45, 38) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M45,34 L46.5,36.5 L49,38 L46.5,39.5 L45,42 L43.5,39.5 L41,38 L43.5,36.5 Z" />
    <!-- Top-right star, centre (63, 38) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M63,34 L64.5,36.5 L67,38 L64.5,39.5 L63,42 L61.5,39.5 L59,38 L61.5,36.5 Z" />
    <!-- Bottom-left star, centre (45, 72) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M45,68 L46.5,70.5 L49,72 L46.5,73.5 L45,76 L43.5,73.5 L41,72 L43.5,70.5 Z" />
    <!-- Bottom-right star, centre (63, 72) -->
    <path
        android:fillColor="#C4972A"
        android:pathData="M63,68 L64.5,70.5 L67,72 L64.5,73.5 L63,76 L61.5,73.5 L59,72 L61.5,70.5 Z" />

</vector>
